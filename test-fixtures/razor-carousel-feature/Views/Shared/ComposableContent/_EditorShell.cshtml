@using KelpApiDomain
@model ComposableEditorViewModel

@foreach (var part in Model.Parts)
{
    var config = PageMediaBlockConfig.FromJson(part.ConfigJson, part.Content);
    if (part.ComponentType == PagePartComponentTypes.Carousel)
    {
        <section class="composable-editor" data-media-kind="carousel">
            <input type="hidden" name="Parts[0].ConfigJson" value="@part.ConfigJson" data-config-json />
            <input type="text" data-carousel-field="title" value="@config.Title" />
            <div data-carousel-items>
                <article data-carousel-item>
                    <input type="text" data-carousel-field="mediaSid" value="@config.MediaSid" />
                    <input type="text" data-carousel-field="url" value="@config.Url" />
                    <textarea data-carousel-field="caption">@config.Caption</textarea>
                </article>
            </div>
            <button type="button" data-action="add-carousel-item">Add image</button>
        </section>
    }
}

<script>
function getCarouselItems(section) {
    return Array.from(section.querySelectorAll('[data-carousel-item]')).map(item => ({
        mediaSid: item.querySelector('[data-carousel-field="mediaSid"]').value,
        url: item.querySelector('[data-carousel-field="url"]').value,
        caption: item.querySelector('[data-carousel-field="caption"]').value
    }));
}

function applyConfig(section) {
    const configInput = document.querySelector('[data-config-json]');
    const payload = {
        title: section.querySelector('[data-carousel-field="title"]').value,
        items: getCarouselItems(section)
    };
    configInput.value = JSON.stringify(payload);
    writePartConfig(configInput, payload);
}

function writePartConfig(input, payload) {
    input.value = JSON.stringify(payload);
}

document.querySelector('[data-action="add-carousel-item"]').addEventListener('click', () => {
    const section = document.querySelector('[data-media-kind="carousel"]');
    applyConfig(section);
});
</script>

@await Component.InvokeAsync("Carousel", new { config = PageMediaBlockConfig.FromJson(Model.PreviewConfigJson, "") })
