{
  "name": "kraken-atlas",
  "displayName": "Kraken Atlas",
  "description": "Maps C#/.NET Core, React/TypeScript, vanilla JavaScript, and HTML/Razor codebases into local queryable code facts for AI context reduction.",
  "version": "0.2.3",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#06172f",
    "theme": "dark"
  },
  "publisher": "BinaryKraken",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-agent",
    "agent",
    "code-map",
    "code-analysis",
    "context-reduction",
    "token-reduction",
    "workspace-index",
    "relationships",
    "feature-flow",
    "csharp",
    "dotnet",
    "aspnetcore",
    "razor",
    "javascript",
    "react",
    "typescript",
    "jsx",
    "tsx",
    "html"
  ],
  "activationEvents": [
    "onCommand:krakenAtlas.rebuildIndex",
    "onCommand:krakenAtlas.updateIndex",
    "onCommand:krakenAtlas.doctor",
    "onCommand:krakenAtlas.showProject",
    "onCommand:krakenAtlas.queryFlow",
    "onCommand:krakenAtlas.querySymbol",
    "onCommand:krakenAtlas.queryReferences",
    "onCommand:krakenAtlas.queryRelationships",
    "onCommand:krakenAtlas.searchMap",
    "onCommand:krakenAtlas.exportContextPack",
    "onCommand:krakenAtlas.installAgentInstructions",
    "onCommand:krakenAtlas.installWorkspaceCli",
    "onCommand:krakenAtlas.installAiAgentSetup",
    "onCommand:krakenAtlas.openMapFolder",
    "workspaceContains:.kraken-atlas/manifest.json"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "kraken-atlas": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "node_modules/sql.js/package.json",
    "node_modules/sql.js/dist/sql-wasm.js",
    "node_modules/sql.js/dist/sql-wasm.wasm",
    "analyzers/dotnet/KrakenAtlas.RoslynAnalyzer/*.csproj",
    "analyzers/dotnet/KrakenAtlas.RoslynAnalyzer/*.cs",
    "analyzers/dotnet/KrakenAtlas.RoslynAnalyzer/publish/**",
    "images/**",
    "AGENT_SKILL.md",
    "ALPHA_FEEDBACK.md",
    "README.md",
    "CHANGELOG.md",
    "GETTING_STARTED.md",
    "NEXT_STEPS.md",
    "PRODUCT_REQUIREMENTS.md",
    "WHERE_WE_LEFT_OFF.md",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "krakenAtlas.rebuildIndex",
        "title": "Kraken Atlas: Rebuild Map From Workspace"
      },
      {
        "command": "krakenAtlas.updateIndex",
        "title": "Kraken Atlas: Update Map For Changed Files"
      },
      {
        "command": "krakenAtlas.doctor",
        "title": "Kraken Atlas: Check Map Health"
      },
      {
        "command": "krakenAtlas.showProject",
        "title": "Kraken Atlas: Show Project Summary"
      },
      {
        "command": "krakenAtlas.queryFlow",
        "title": "Kraken Atlas: Trace Feature Flow"
      },
      {
        "command": "krakenAtlas.querySymbol",
        "title": "Kraken Atlas: Find Symbol"
      },
      {
        "command": "krakenAtlas.queryReferences",
        "title": "Kraken Atlas: Find References"
      },
      {
        "command": "krakenAtlas.queryRelationships",
        "title": "Kraken Atlas: Show Relationships"
      },
      {
        "command": "krakenAtlas.searchMap",
        "title": "Kraken Atlas: Search Map"
      },
      {
        "command": "krakenAtlas.exportContextPack",
        "title": "Kraken Atlas: Export Context Pack"
      },
      {
        "command": "krakenAtlas.installAgentInstructions",
        "title": "Kraken Atlas: Install Agent Instructions"
      },
      {
        "command": "krakenAtlas.installWorkspaceCli",
        "title": "Kraken Atlas: Install CLI For Workspace Terminals"
      },
      {
        "command": "krakenAtlas.installAiAgentSetup",
        "title": "Kraken Atlas: Install AI Agent Setup"
      },
      {
        "command": "krakenAtlas.openMapFolder",
        "title": "Kraken Atlas: Open Map Folder"
      }
    ],
    "languageModelTools": [
      {
        "name": "kraken_atlas_doctor",
        "displayName": "Kraken Atlas: Check Map Health",
        "modelDescription": "Check whether the local Kraken Atlas code map is ready, stale, missing, or degraded before reading source files.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "kraken_atlas_query",
        "displayName": "Kraken Atlas: Query Code Map",
        "modelDescription": "Query the local Kraken Atlas relationship map before opening source files. Use relationships for a known file or symbol, references for usages, flow for connected behavior, symbol for declarations, search for fallback discovery, and project for a map summary.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "queryType": {
              "type": "string",
              "enum": [
                "project",
                "flow",
                "relationships",
                "search",
                "symbol",
                "references"
              ],
              "description": "The direct map query to run."
            },
            "query": {
              "type": "string",
              "description": "Natural-language task, symbol name, file path, route, pattern, or search text."
            },
            "context": {
              "type": "string",
              "description": "Optional project or folder context for multi-project workspaces, such as WebUI or AdminTools."
            }
          },
          "required": [
            "queryType"
          ]
        }
      },
      {
        "name": "kraken_atlas_context_pack",
        "displayName": "Kraken Atlas: Export Context Pack",
        "modelDescription": "Create a compact markdown context pack from a narrowed Kraken Atlas query after likely edit files have been identified.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "queryType": {
              "type": "string",
              "enum": [
                "flow",
                "relationships",
                "search",
                "symbol",
                "references",
                "project"
              ],
              "description": "The source query type for the context pack."
            },
            "query": {
              "type": "string",
              "description": "Natural-language task, symbol name, file path, route, pattern, or search text."
            },
            "context": {
              "type": "string",
              "description": "Optional project or folder context for multi-project workspaces."
            }
          },
          "required": [
            "query"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Kraken Atlas",
      "properties": {
        "krakenAtlas.outputFolder": {
          "type": "string",
          "default": ".kraken-atlas",
          "description": "Workspace-relative folder where Kraken Atlas outputs are written."
        },
        "krakenAtlas.maxFileSizeBytes": {
          "type": "number",
          "default": 1048576,
          "description": "Maximum file size to index."
        },
        "krakenAtlas.updateOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Update Kraken Atlas after saving supported C#/.NET, React/TypeScript, vanilla JavaScript, HTML, or Razor files."
        },
        "krakenAtlas.excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directory names to exclude from indexing."
        },
        "krakenAtlas.excludeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional workspace-relative glob patterns to exclude from indexing."
        },
        "krakenAtlas.excludeExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional file extensions to exclude from indexing, such as .bak or .tmp."
        },
        "krakenAtlas.excludeFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional file names or workspace-relative file paths to exclude from indexing."
        },
        "krakenAtlas.includeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Workspace-relative glob patterns to include even when a broader ignore rule would exclude them."
        },
        "krakenAtlas.ignoreFile": {
          "type": "string",
          "default": ".kraken-atlas-ignore",
          "description": "Workspace-relative ignore file used for Kraken Atlas scan rules."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "publish:analyzer": "dotnet publish analyzers/dotnet/KrakenAtlas.RoslynAnalyzer/KrakenAtlas.RoslynAnalyzer.csproj -c Release -o analyzers/dotnet/KrakenAtlas.RoslynAnalyzer/publish",
    "pack:dry": "npm pack --dry-run",
    "package:vsix": "node scripts/vsce-package.cjs package --no-rewrite-relative-links --allow-missing-repository --skip-license",
    "release:bump": "node scripts/release-bump.cjs",
    "release:check-version": "node scripts/release-check-version.cjs",
    "release:history-from-vsix": "node scripts/release-history-from-vsix.cjs",
    "release:vsix": "node scripts/release-vsix.cjs",
    "check:vsix": "npm run compile && npm run publish:analyzer && npm run package:vsix",
    "check:package": "npm run compile && npm run publish:analyzer && npm pack --dry-run",
    "test": "npm run compile && npm run compile:test && node --test --test-concurrency=1 \"dist-test/test/**/*.js\"",
    "vscode:prepublish": "node -e \"\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "sql.js": "^1.14.1"
  }
}
