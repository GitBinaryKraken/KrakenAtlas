{
  "name": "kraken-atlas",
  "displayName": "Kraken Atlas",
  "description": "Builds a local SQLite Atlas of .NET code, DI, HTTP routes, and database relationships for compact AI-agent queries.",
  "version": "0.5.0",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#06172f",
    "theme": "dark"
  },
  "publisher": "BinaryKraken",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitBinaryKraken/KrakenAtlas.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    },
    "virtualWorkspaces": false
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-agent",
    "code-map",
    "code-analysis",
    "context-reduction",
    "csharp",
    "dotnet",
    "aspnetcore",
    "database",
    "react",
    "typescript"
  ],
  "activationEvents": [
    "onCommand:krakenAtlas.showStatus",
    "onCommand:krakenAtlas.buildAtlas",
    "onCommand:krakenAtlas.showAtlasSummary",
    "onCommand:krakenAtlas.showWorkspaceOrientation",
    "onCommand:krakenAtlas.lookupEntity",
    "onCommand:krakenAtlas.searchSymbols",
    "onCommand:krakenAtlas.searchEntities",
    "onCommand:krakenAtlas.findUsages",
    "onCommand:krakenAtlas.showRelations",
    "onCommand:krakenAtlas.traceRoute",
    "onCommand:krakenAtlas.restartCartographer",
    "onCommand:krakenAtlas.exportDiagnostics",
    "onCommand:krakenAtlas.openPlanning"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "cartographer/KrakenAtlas.Cartographer/publish/**",
    "docs/planning/**",
    "images/**",
    "README.md",
    "CHANGELOG.md",
    "GETTING_STARTED.md",
    "ALPHA_TESTING.md",
    "PRIVACY.md",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "krakenAtlas.showStatus",
        "title": "Kraken Atlas: Show Status",
        "icon": "$(pulse)"
      },
      {
        "command": "krakenAtlas.buildAtlas",
        "title": "Kraken Atlas: Build Atlas",
        "icon": "$(database)"
      },
      {
        "command": "krakenAtlas.showAtlasSummary",
        "title": "Kraken Atlas: Show Atlas Summary",
        "icon": "$(list-tree)"
      },
      {
        "command": "krakenAtlas.showWorkspaceOrientation",
        "title": "Kraken Atlas: Show Workspace Orientation",
        "icon": "$(map)"
      },
      {
        "command": "krakenAtlas.lookupEntity",
        "title": "Kraken Atlas: Lookup Entity",
        "icon": "$(symbol-key)"
      },
      {
        "command": "krakenAtlas.searchSymbols",
        "title": "Kraken Atlas: Search C# Symbols",
        "icon": "$(search)"
      },
      {
        "command": "krakenAtlas.searchEntities",
        "title": "Kraken Atlas: Search Entities",
        "icon": "$(search-fuzzy)"
      },
      {
        "command": "krakenAtlas.findUsages",
        "title": "Kraken Atlas: Find C# Usages",
        "icon": "$(references)"
      },
      {
        "command": "krakenAtlas.showRelations",
        "title": "Kraken Atlas: Show Relations",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "krakenAtlas.traceRoute",
        "title": "Kraken Atlas: Trace Route",
        "icon": "$(git-compare)"
      },
      {
        "command": "krakenAtlas.restartCartographer",
        "title": "Kraken Atlas: Restart Cartographer",
        "icon": "$(refresh)"
      },
      {
        "command": "krakenAtlas.exportDiagnostics",
        "title": "Kraken Atlas: Export Diagnostics",
        "icon": "$(export)"
      },
      {
        "command": "krakenAtlas.openPlanning",
        "title": "Kraken Atlas: Open Architecture Plan",
        "icon": "$(book)"
      }
    ]
  },
  "scripts": {
    "clean:extension": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:tests": "node -e \"require('node:fs').rmSync('dist-test', { recursive: true, force: true })\"",
    "clean:cartographer-publish": "node -e \"require('node:fs').rmSync('cartographer/KrakenAtlas.Cartographer/publish', { recursive: true, force: true })\"",
    "compile": "npm run clean:extension && tsc -p ./tsconfig.json",
    "compile:test": "npm run clean:tests && tsc -p ./tsconfig.test.json",
    "build:cartographer": "dotnet build KrakenAtlas.slnx -c Release",
    "publish:cartographer": "npm run clean:cartographer-publish && dotnet publish cartographer/KrakenAtlas.Cartographer/KrakenAtlas.Cartographer.csproj -c Release -o cartographer/KrakenAtlas.Cartographer/publish --no-self-contained",
    "test:node": "node --test --test-concurrency=1 \"dist-test/test/**/*.js\"",
    "test": "npm run compile && npm run build:cartographer && npm run compile:test && npm run test:node",
    "package:vsix": "node scripts/vsce-package.cjs package --no-rewrite-relative-links --allow-missing-repository --skip-license",
    "check:vsix": "npm test && npm run publish:cartographer && npm run package:vsix",
    "smoke:vsix": "node scripts/smoke-test-vsix.cjs",
    "release:bump": "node scripts/release-bump.cjs",
    "release:check-version": "node scripts/release-check-version.cjs",
    "release:vsix": "node scripts/release-vsix.cjs",
    "vscode:prepublish": "npm run compile && npm run publish:cartographer"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "ajv": "^8.20.0",
    "typescript": "^5.4.5"
  }
}
